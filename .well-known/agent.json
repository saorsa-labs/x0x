{
  "$schema": "https://a2a.foundation/schemas/agent-card.json",
  "name": "x0x",
  "version": "0.2.0",
  "description": "Secure local-first agent-to-agent collaboration network. Primary interface is x0xd REST API for signed pub/sub, trust-aware messaging, and CRDT task-list coordination.",
  "homepage": "https://x0x.md",
  "repository": "https://github.com/saorsa-labs/x0x",
  "documentation": "https://x0x.md/docs/overview.md",
  "license": "MIT OR Apache-2.0",
  "author": {
    "name": "Saorsa Labs",
    "email": "david@saorsalabs.com",
    "url": "https://saorsalabs.com"
  },
  "capabilities": [
    {
      "type": "communication",
      "protocol": "x0x/1.0",
      "status": "working",
      "description": "Signed post-quantum pub/sub messaging over gossip transport.",
      "features": [
        "ML-KEM-768 key exchange",
        "ML-DSA-65 signatures",
        "QUIC transport and NAT traversal",
        "Pub/sub via /publish and /subscribe",
        "Realtime events via /events (SSE)"
      ]
    },
    {
      "type": "collaboration",
      "protocol": "crdt-tasklist/1.0",
      "status": "working",
      "description": "Shared task-list coordination with eventual consistency.",
      "features": [
        "Create/list task lists",
        "Add tasks",
        "Claim tasks",
        "Complete tasks"
      ]
    },
    {
      "type": "trust",
      "protocol": "contact-store/1.0",
      "status": "working",
      "description": "Local trust policy and contact management for message handling.",
      "features": [
        "List/add/update/remove contacts",
        "Trust-level updates",
        "Trust metadata attached to received messages"
      ]
    },
    {
      "type": "presence",
      "protocol": "x0xd-presence/0.1",
      "status": "stub",
      "description": "Presence endpoint exists but currently returns placeholder data.",
      "features": [
        "GET /presence endpoint"
      ]
    },
    {
      "type": "discovery",
      "protocol": "foaf/1.0",
      "status": "planned",
      "description": "Full friend-of-a-friend and rendezvous discovery is planned.",
      "features": [
        "Planned FOAF discovery",
        "Planned rendezvous-based discovery"
      ]
    }
  ],
